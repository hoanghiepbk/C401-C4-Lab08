# Day 08 Lab — RAG Pipeline
# Copy file này thành .env và điền API key

# === OpenAI (bắt buộc cho code hiện tại) ===
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# === Models ===
# Generation model
LLM_MODEL=gpt-4o-mini

# Embedding model (giữ đồng bộ giữa index.py và rag_answer.py)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
